@model Smart_Library_Management_System.Models.Book

@{
    ViewData["Title"] = "Book Details";
}

<h1>📖 Book Details</h1>
<hr />

<div class="card shadow-sm" style="max-width: 600px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Title</dt>
            <dd class="col-sm-8">@Model.Title</dd>

            <dt class="col-sm-4">Author</dt>
            <dd class="col-sm-8">@Model.Author</dd>

            <dt class="col-sm-4">Price</dt>
            <dd class="col-sm-8">@Model.Price.ToString("F2") DH</dd>

            <dt class="col-sm-4">Stock</dt>
            <dd class="col-sm-8">
                <span class="badge @(Model.StockQuantity > 0 ? "bg-success" : "bg-danger")">
                    @Model.StockQuantity available
                </span>
            </dd>

            <dt class="col-sm-4">Category</dt>
            <dd class="col-sm-8">@(Model.Category?.Name ?? "—")</dd>
        </dl>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.BookID" class="btn btn-warning">
        ✏️ Edit
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        ← Back to List
    </a>
</div>
</div>